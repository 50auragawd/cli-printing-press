func newWorkflowArchiveCmd(flags *rootFlags) *cobra.Command {
	var dbPath string
	var full bool

	cmd := &cobra.Command{
		Use:   "archive",
		Short: "Sync all resources to local store for offline access and search",
		Long: `Archive fetches all syncable resources from the API and stores them in a
local SQLite database. Supports incremental sync (only new data since last run)
and full resync. After archiving, use 'search' for instant full-text search.`,
		Example: `  # Archive all resources
  {{.Name}}-pp-cli workflow archive

  # Full re-archive (ignore previous sync state)
  {{.Name}}-pp-cli workflow archive --full`,
		RunE: func(cmd *cobra.Command, args []string) error {
			c, err := flags.newClient()
			if err != nil {
				return err
			}
			c.NoCache = true

			if dbPath == "" {
				dbPath = defaultDBPath()
			}
			s, err := store.Open(dbPath)
			if err != nil {
				return fmt.Errorf("opening store: %w", err)
			}
			defer s.Close()

			type archiveResourceConfig struct {
				name string
				path string
				limitParam string
				pageSize int
			}
			resources := []archiveResourceConfig{
			{{- range .SyncResources}}
				{name: "{{.Name}}", path: "{{.Path}}", limitParam: "{{if .LimitParam}}{{.LimitParam}}{{else}}limit{{end}}", pageSize: {{if .DefaultLimit}}{{.DefaultLimit}}{{else}}100{{end}}},
			{{- end}}
			}
			totalSynced := 0

			for _, res := range resources {
				cursor := ""
				if !full {
					existing, _, _, err := s.GetSyncState(res.name)
					if err == nil && existing != "" {
						cursor = existing
					}
				}

				fmt.Fprintf(cmd.ErrOrStderr(), "Syncing %s...\n", res.name)

				params := map[string]string{res.limitParam: fmt.Sprintf("%d", res.pageSize)}
				if cursor != "" {
					params["after"] = cursor
				}

				count := 0
				for {
					data, fetchErr := c.Get(res.path, params)
					if fetchErr != nil {
						fmt.Fprintf(cmd.ErrOrStderr(), "  warning: %s: %v\n", res.name, fetchErr)
						break
					}
					// Try to extract items from response envelope
					var items []json.RawMessage
					if err := json.Unmarshal(data, &items); err != nil {
						var env struct{ Data []json.RawMessage `json:"data"` }
						if err2 := json.Unmarshal(data, &env); err2 == nil && len(env.Data) > 0 {
							items = env.Data
						} else {
							if err := s.Upsert(res.name, res.name+"-singleton", data); err != nil {
								fmt.Fprintf(cmd.ErrOrStderr(), "  warning: store %s: %v\n", res.name, err)
							}
							count++
							break
						}
					}
					if len(items) == 0 {
						break
					}
					if err := s.UpsertBatch(res.name, items); err != nil {
						fmt.Fprintf(cmd.ErrOrStderr(), "  warning: batch store %s: %v\n", res.name, err)
						break
					}
					count += len(items)
					if len(items) < res.pageSize {
						break
					}
				}

				if count > 0 {
					s.SaveSyncState(res.name, "", count)
				}
				totalSynced += count
				fmt.Fprintf(cmd.ErrOrStderr(), "  %s: %d items\n", res.name, count)
			}

			if flags.asJSON {
				enc := json.NewEncoder(cmd.OutOrStdout())
				enc.SetIndent("", "  ")
				return enc.Encode(map[string]any{
					"resources_synced": len(resources),
					"total_items":      totalSynced,
					"store_path":       dbPath,
					"timestamp":        time.Now().UTC().Format(time.RFC3339),
				})
			}

			fmt.Fprintf(cmd.OutOrStdout(), "Archived %d items across %d resources to %s\n", totalSynced, len(resources), dbPath)
			return nil
		},
	}

	cmd.Flags().StringVar(&dbPath, "db", "", "Database path (default: ~/.local/share/{{.Name}}-pp-cli/data.db)")
	cmd.Flags().BoolVar(&full, "full", false, "Full re-archive (ignore previous sync state)")

	return cmd
}

func newWorkflowStatusCmd(flags *rootFlags) *cobra.Command {
	var dbPath string

	cmd := &cobra.Command{
		Use:   "status",
		Short: "Show local archive status and sync state for all resources",
		Example: `  # Show archive status
  {{.Name}}-pp-cli workflow status

  # Show status as JSON
  {{.Name}}-pp-cli workflow status --json`,
		RunE: func(cmd *cobra.Command, args []string) error {
			if dbPath == "" {
				dbPath = defaultDBPath()
			}
			s, err := store.Open(dbPath)
			if err != nil {
				return fmt.Errorf("opening store: %w", err)
			}
			defer s.Close()

			status, err := s.Status()
			if err != nil {
				return err
			}

			if flags.asJSON {
				enc := json.NewEncoder(cmd.OutOrStdout())
				enc.SetIndent("", "  ")
				return enc.Encode(status)
			}

			if len(status) == 0 {
				fmt.Fprintln(cmd.OutOrStdout(), "No archived data. Run 'workflow archive' to sync.")
				return nil
			}

			fmt.Fprintln(cmd.OutOrStdout(), "Archive Status:")
			total := 0
			for resource, count := range status {
				fmt.Fprintf(cmd.OutOrStdout(), "  %-30s %d items\n", resource, count)
				total += count
			}
			fmt.Fprintf(cmd.OutOrStdout(), "\n  Total: %d items\n", total)
			fmt.Fprintf(cmd.OutOrStdout(), "  Store: %s\n", dbPath)
			return nil
		},
	}

	cmd.Flags().StringVar(&dbPath, "db", "", "Database path")

	return cmd
